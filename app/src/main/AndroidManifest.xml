<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
    <!--
        读取 MediaStore.Audio：API ≤ 32 用 READ_EXTERNAL_STORAGE；
        API ≥ 33 (Android 13) 改用 READ_MEDIA_AUDIO，READ_EXTERNAL_STORAGE 自动失效。
    -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ScanPenApp">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".AskAiActivity"
            android:exported="false"
            android:label="@string/title_ask_ai"
            android:screenOrientation="landscape" />

        <!-- AI 回答全屏查看页：双击 AI 回答气泡跳转，关闭后回到 AskAiActivity -->
        <activity
            android:name=".AiMessageFullscreenActivity"
            android:exported="false"
            android:label="@string/ai_fullscreen_title"
            android:screenOrientation="landscape" />

        <activity
            android:name=".MicroChatActivity"
            android:exported="false"
            android:label="@string/title_micro_chat"
            android:screenOrientation="landscape" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/title_settings"
            android:screenOrientation="landscape" />

        <activity
            android:name=".AboutDeviceActivity"
            android:exported="false"
            android:label="@string/about_title"
            android:screenOrientation="landscape" />

        <activity
            android:name=".SettingsSliderActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".ai.AiSettingsActivity"
            android:exported="false"
            android:label="@string/ai_settings_title"
            android:screenOrientation="landscape" />

        <activity
            android:name=".ai.QrScanActivity"
            android:exported="false"
            android:label="@string/qr_scan_title"
            android:screenOrientation="landscape" />

        <activity
            android:name=".ai.QrShareActivity"
            android:exported="false"
            android:label="@string/qr_share_title"
            android:screenOrientation="landscape" />

        <activity
            android:name=".ai.QrPreviewActivity"
            android:exported="false"
            android:label="@string/qr_preview_title"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar" />

        <activity
            android:name=".CameraActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".RecorderActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!--
            FileProvider：供拍照 launcher (ActivityResultContracts.TakePicture) 写入临时照片。
            - authority 走 ${applicationId}.fileprovider 避免与其它模块冲突。
            - 路径在 res/xml/file_paths.xml 配置（仅暴露 cache-path "captures"）。
            - exported=false、grantUriPermissions=true 满足系统相机写 Uri 授权需求。
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
