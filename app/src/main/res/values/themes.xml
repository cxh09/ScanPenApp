<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ScanPenApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- 强制全屏：隐藏状态栏与标题栏，由各 Activity 进一步隐藏导航栏 -->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!--
        强制深色弹窗主题：用于设置页的 SeekBar 弹窗（亮度/声音）。
        覆盖 AppCompat AlertDialog 的窗口背景、标题与按钮文字色，避免在浅色模式下出现白底弹窗。
    -->
    <style name="Theme.ScanPenApp.Dialog" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@color/ai_input_bg</item>
        <item name="android:colorBackground">@color/ai_input_bg</item>
        <item name="android:textColorPrimary">@color/ai_text_primary</item>
        <item name="android:textColorSecondary">@color/ai_text_secondary</item>
        <item name="colorAccent">@color/ai_input_focus_border</item>
        <item name="colorControlNormal">@color/ai_text_primary</item>
        <item name="colorControlActivated">@color/ai_input_focus_border</item>
        <item name="colorControlHighlight">@color/ai_sidebar_active</item>
    </style>
</resources>