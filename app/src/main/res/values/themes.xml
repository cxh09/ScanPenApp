<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ScanPenApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/gray_white_primary</item>
        <item name="colorPrimaryVariant">@color/gray_white_primary_variant</item>
        <item name="colorOnPrimary">@color/gray_white_on_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/gray_white_secondary</item>
        <item name="colorSecondaryVariant">@color/gray_white_secondary_variant</item>
        <item name="colorOnSecondary">@color/gray_white_on_secondary</item>
        <!-- 强制全屏：隐藏状态栏与标题栏，由各 Activity 进一步隐藏导航栏 -->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- 深色 AlertDialog：用于长按历史删除提示等场景，与全站深色 UI 对齐
         父样式 Theme.AppCompat.Dialog.Alert 是 androidx.appcompat 提供的标准 AlertDialog 主题，
         显式覆盖背景色与文字色即可得到深色效果，避免依赖不存在的 Material 父样式 -->
    <style name="Theme.ScanPenApp.AlertDialog.Dark" parent="Theme.AppCompat.Dialog.Alert">
        <item name="colorAccent">@color/ai_input_focus_border</item>
        <item name="android:windowBackground">@color/ai_dialog_bg</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
        <item name="android:colorBackground">@color/ai_dialog_bg</item>
    </style>

    <!-- 关于本机页面：分组标题 -->
    <style name="AboutSectionHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">14dp</item>
        <item name="android:textColor">@color/ai_text_tertiary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>