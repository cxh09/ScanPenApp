<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ScanPenApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/gray_white_primary</item>
        <item name="colorPrimaryVariant">@color/gray_white_primary_variant</item>
        <item name="colorOnPrimary">@color/gray_white_on_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/gray_white_secondary</item>
        <item name="colorSecondaryVariant">@color/gray_white_secondary_variant</item>
        <item name="colorOnSecondary">@color/gray_white_on_secondary</item>
        <!-- 强制全屏：隐藏状态栏与标题栏，由各 Activity 进一步隐藏导航栏 -->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>