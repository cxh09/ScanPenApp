<?xml version="1.0" encoding="utf-8"?>
<!--
    技能「关于」Activity（新版：左右 2 列布局）
    - 顶部 32dp TopBar：← 返回 + 「关于」标题
    - 主区：水平 LinearLayout
        左列（320dp）：icon + 技能名 + 「提供方」标签 + 作者
        中间 1dp 垂直分割线
        右列（weight=1，居中）：技能介绍
    - 与 AskAiActivity 风格统一：深色背景 + 浅色文字
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_chat_bg"
    android:orientation="vertical">

    <!-- ============ TopBar 32dp ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="@color/bg_base"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="8dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:contentDescription="@string/ai_topbar_back"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/ai_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="@string/skill_about_topbar_title"
            android:textColor="@color/ai_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_strong" />

    <!-- ============ 主区：左 320dp / 右 weight=1 ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- 左列：身份卡（icon + 名称 + 提供方） -->
        <LinearLayout
            android:id="@+id/leftCol"
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="48dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_skill_lively"
                app:tint="@color/ai_text_primary" />

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/ai_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="灵动表达" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/skill_about_author_label"
                android:textColor="@color/ai_text_tertiary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/skill_about_author"
                android:textColor="@color/ai_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 中间 1dp 垂直分割线 -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider_strong" />

        <!-- 右列：技能介绍（居中，多行可滚动） -->
        <ScrollView
            android:id="@+id/rightCol"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbarSize="4dp"
            android:scrollbarStyle="outsideInset"
            android:scrollbarThumbVertical="@drawable/scrollbar_thumb_ai"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingTop="32dp"
                android:paddingEnd="32dp"
                android:paddingBottom="32dp">

                <TextView
                    android:id="@+id/tvDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingExtra="6dp"
                    android:textColor="@color/ai_text_secondary"
                    android:textSize="15sp"
                    tools:text="让文字更生动、更有画面感" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</LinearLayout>
