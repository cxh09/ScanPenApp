<?xml version="1.0" encoding="utf-8"?>
<!--
    附件选择面板单卡片（item_attach_entry）：
    - 等宽 2 列（外层 LinearLayout weight=1）
    - 内含 24dp 图标（ivEntryIcon）+ 名称（15sp Medium）
    - 高度统一 96dp，垂直居中
    - 背景 surface/level-1，圆角 12dp，pressed → level-2
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="96dp"
    android:layout_weight="1"
    android:background="@drawable/bg_skill_card"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingTop="12dp"
    android:paddingEnd="8dp"
    android:paddingBottom="12dp">

    <ImageView
        android:id="@+id/ivEntryIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:contentDescription="@null"
        android:scaleType="centerInside" />

    <TextView
        android:id="@+id/tvEntryName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/ai_text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
