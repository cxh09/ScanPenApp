<?xml version="1.0" encoding="utf-8"?>
<!--
    全屏播放页（云音乐）：
    - 顶栏 32dp：左返回 + 中「正在播放」 + 右占位
    - 主体：coverArea（默认 visible）/ lyricArea（默认 gone）切换
    - 底部 96dp 控制栏：SeekBar + 时间 + 模式/上一首/播放/下一首/歌词
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:orientation="vertical">

    <!-- ============ 顶栏 32dp ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageView
            android:id="@+id/btnPlayerBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_topbar_btn"
            android:clickable="true"
            android:contentDescription="@string/ai_settings_back"
            android:focusable="true"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/text_primary" />

        <TextView
            android:id="@+id/tvPlayerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/music_player_title"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- 右侧 40×40 占位（与左侧对称） -->
        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <!-- 1dp 顶部分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_strong" />

    <!-- ============ 主体 ============ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- 封面区（默认 visible） -->
        <LinearLayout
            android:id="@+id/coverArea"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="240dp"
                android:layout_height="240dp">

                <View
                    android:id="@+id/coverPlaceholder"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:background="@drawable/bg_cover_placeholder"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tvCoverInitial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="♪"
                    android:textColor="@color/player_text_primary"
                    android:textSize="80sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvSongName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@color/player_text_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText"
                tools:text="歌名" />

            <TextView
                android:id="@+id/tvArtistName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@color/player_text_tertiary"
                android:textSize="14sp"
                tools:ignore="HardcodedText"
                tools:text="歌手" />
        </LinearLayout>

        <!-- 歌词区（默认 gone） -->
        <ScrollView
            android:id="@+id/lyricArea"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="80dp"
            android:paddingBottom="80dp"
            android:scrollbars="none"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:id="@+id/lyricContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp" />
        </ScrollView>
    </FrameLayout>

    <!-- ============ 底部 96dp 控制栏 ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:background="@color/player_mini_bg"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <SeekBar
            android:id="@+id/sbProgress"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/player_seekbar_tint"
            android:thumbTint="@color/player_seekbar_tint" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPosition"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:text="0:00"
                android:textColor="@color/player_text_tertiary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="0:00"
                android:textColor="@color/player_text_tertiary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnPlayerMode"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_player_btn"
                android:clickable="true"
                android:contentDescription="@string/music_player_mode_normal"
                android:focusable="true"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_player_mode_normal"
                app:tint="@color/player_mode_inactive_tint" />

            <ImageView
                android:id="@+id/btnPlayerPrev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_player_btn"
                android:clickable="true"
                android:contentDescription="@string/music_player_prev"
                android:focusable="true"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_player_prev"
                app:tint="@color/player_text_primary" />

            <ImageView
                android:id="@+id/btnPlayerPlayPause"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_player_btn"
                android:clickable="true"
                android:contentDescription="@string/music_player_play"
                android:focusable="true"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_player_play"
                app:tint="@color/player_text_primary" />

            <ImageView
                android:id="@+id/btnPlayerNext"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_player_btn"
                android:clickable="true"
                android:contentDescription="@string/music_player_next"
                android:focusable="true"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_player_next"
                app:tint="@color/player_text_primary" />

            <ImageView
                android:id="@+id/btnPlayerLyric"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_player_btn"
                android:clickable="true"
                android:contentDescription="@string/music_player_toggle_lyric"
                android:focusable="true"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_lyric"
                app:tint="@color/player_mode_inactive_tint" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
