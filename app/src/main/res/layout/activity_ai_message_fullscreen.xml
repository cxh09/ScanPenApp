<?xml version="1.0" encoding="utf-8"?>
<!--
    AI 回答全屏查看页（横屏）：
    - 顶部 48dp 工具栏：左侧"← 返回" + 当前对话标题（AskAiActivity 动态传入；fallback 为"AI 回答"）
    - 主体：ScrollView + TextView（18sp / 次级行距 / textIsSelectable 支持长按选择复制）
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_chat_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/ai_sidebar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="48dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/ai_fullscreen_back"
            android:textColor="@color/ai_text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/ai_fullscreen_title"
            android:textColor="@color/ai_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!--
        滚动条优化（避免长内容下滚动条过于突兀）：
        - scrollbarSize=4dp：比默认更细
        - scrollbarThumbVertical：自定义圆角灰色 thumb（drawable/scrollbar_thumb_ai）
        - scrollbarStyle=outsideInset：thumb 绘制在 padding 之外（贴右屏幕边缘），不压缩文字区域
        - scrollbarDefaultDelayBeforeFade=100：滚动停下 100ms 后开始淡出
        - scrollbarFadeDuration=200：淡出 200ms 完成（比默认 250ms 略快）
        - clipToPadding=false：thumb 淡出过程中 padding 仍生效，文字不抖
    -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:scrollbarDefaultDelayBeforeFade="100"
        android:scrollbarFadeDuration="200"
        android:scrollbarSize="4dp"
        android:scrollbarStyle="outsideInset"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb_ai">

        <TextView
            android:id="@+id/tvContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/ai_msg_ai_text"
            android:textIsSelectable="true"
            android:textSize="18sp" />
    </ScrollView>
</LinearLayout>
