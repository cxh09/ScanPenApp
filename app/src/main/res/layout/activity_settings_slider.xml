<?xml version="1.0" encoding="utf-8"?>
<!--
    设置 → 亮度 / 声音 调节页：
    - 顶部栏 48dp（返回 + 居中标题），与 SettingsActivity 风格保持一致。
    - 主体：百分比 + SeekBar，垂直居中。
    - 配色沿用 ai_chat_bg / ai_input_* / ai_text_*，与全 App 深色风格统一。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_chat_bg"
    android:orientation="vertical">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_topbar_btn"
            android:clickable="true"
            android:contentDescription="@string/ai_settings_back"
            android:focusable="true"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/ai_text_primary" />

        <TextView
            android:id="@+id/tvSliderTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/ai_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="亮度" />

        <View
            android:layout_width="48dp"
            android:layout_height="match_parent" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ai_sidebar_divider" />

    <!-- 调节区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="40dp"
        android:paddingEnd="40dp">

        <TextView
            android:id="@+id/tvSliderValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ai_text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            tools:text="50%" />

        <SeekBar
            android:id="@+id/slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:max="100"
            android:progressBackgroundTint="@color/ai_input_border"
            android:progressTint="@color/ai_input_focus_border"
            android:thumbTint="@color/ai_text_primary"
            tools:progress="50" />

    </LinearLayout>

</LinearLayout>
