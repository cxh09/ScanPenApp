<?xml version="1.0" encoding="utf-8"?>
<!--
    云音乐 → 服务器设置页：
    - 顶部栏 48dp（返回 + 居中标题），与 SettingsActivity 风格保持一致。
    - 主体：服务器地址 + 端口 两个输入框 + 保存按钮。
    - 配色沿用 ai_chat_bg / ai_input_* / ai_text_*，与全 App 深色风格统一。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_chat_bg"
    android:orientation="vertical">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/btnMusicServerBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_topbar_btn"
            android:clickable="true"
            android:contentDescription="@string/ai_settings_back"
            android:focusable="true"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/ai_text_primary" />

        <TextView
            android:id="@+id/tvMusicServerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/music_settings_title"
            android:textColor="@color/ai_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="48dp"
            android:layout_height="match_parent" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ai_sidebar_divider" />

    <!-- 表单区 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="20dp"
            android:paddingEnd="24dp"
            android:paddingBottom="20dp">

            <!-- 服务器地址 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/music_settings_server_address"
                android:textColor="@color/ai_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etMusicServerAddress"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="@string/music_settings_server_address_hint"
                android:imeOptions="actionNext"
                android:inputType="textUri"
                android:maxLines="1"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:textColor="@color/ai_text_primary"
                android:textColorHint="@color/ai_text_tertiary"
                android:textSize="14sp"
                tools:ignore="Autofill,LabelFor" />

            <!-- 端口 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/music_settings_server_port"
                android:textColor="@color/ai_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etMusicServerPort"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="@string/music_settings_server_port_hint"
                android:imeOptions="actionDone"
                android:inputType="number"
                android:maxLength="5"
                android:maxLines="1"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:textColor="@color/ai_text_primary"
                android:textColorHint="@color/ai_text_tertiary"
                android:textSize="14sp"
                tools:ignore="Autofill,LabelFor" />

            <!-- 保存按钮 -->
            <TextView
                android:id="@+id/btnMusicServerSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_main_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/ai_settings_save"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
