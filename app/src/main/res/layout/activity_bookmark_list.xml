<?xml version="1.0" encoding="utf-8"?>
<!--
    收藏列表页（横屏 1:4）：
    - 顶部 48dp 工具栏：「← 返回」+ 标题 + 数量 + 1dp 分隔线
    - 主体：左侧 ListView（收藏条目）+ 右侧 ScrollView+TextView（详情内容）
    - 深色主题，颜色全部 @color/ai_*，字符串全部 @string/ai_*
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_chat_bg"
    android:orientation="vertical">

    <!-- 顶部工具栏：48dp，sidebar 背景 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/ai_sidebar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:contentDescription="@string/ai_fullscreen_back"
            android:focusable="true"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/ai_text_primary" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingStart="8dp"
            android:text="@string/ai_bookmark_view_title"
            android:textColor="@color/ai_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingEnd="16dp"
            android:text=""
            android:textColor="@color/ai_text_tertiary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 工具栏与主体之间的 1dp 分隔线 -->
    <View
        android:id="@+id/toolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ai_sidebar_divider" />

    <!-- 主体：左侧列表（3/10）+ 竖分隔线 + 右侧详情（7/10） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <ListView
            android:id="@+id/lvBookmarks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:divider="@null"
            android:listSelector="?attr/selectableItemBackground"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:scrollbars="none" />

        <View
            android:id="@+id/contentDivider"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/ai_sidebar_divider" />

        <LinearLayout
            android:id="@+id/contentArea"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="7"
            android:orientation="vertical">

            <ScrollView
                android:id="@+id/svContent"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/ai_msg_ai_text"
                    android:textIsSelectable="true"
                    android:textSize="15sp" />
            </ScrollView>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
