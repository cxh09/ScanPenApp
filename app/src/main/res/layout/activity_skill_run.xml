<?xml version="1.0" encoding="utf-8"?>
<!--
    技能运行页（灵动表达 / 翻译 / 写作 共用）：
    - 根 DrawerLayout：第一个子 = 主内容（左侧 80dp 边栏 + 右侧上下 1:1 分割区），第二个子 = 右侧模型选择抽屉
    - 主内容：左侧 80dp 边栏（返回 / API 设置 / 关于） + 右侧主区（输入 / 输出）
    - 输入区：EditText（多行，可滚动）+ 模型按钮 + 运行按钮
    - 输出区：ScrollView + TextView（textIsSelectable=true，长按可选中复制）
    - 模型抽屉：与 AskAiActivity 同款（标题 + 关闭 + 模型列表 + 跳 AI 服务入口），由 ModelDrawerBinder 绑定
    - 整体背景 ai_chat_bg（#000000），风格与 AskAiActivity 主区统一
    - 抽屉默认 lockMode=locked，仅 btnModel 可触发打开，避免误滑
-->
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ============ 主内容 ============ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ai_chat_bg">

        <!-- ============ 左侧边栏（3 个 icon+文字 按钮，纵向均分 1/3 高度） ============ -->
        <LinearLayout
            android:id="@+id/sidebar"
            android:layout_width="80dp"
            android:layout_height="0dp"
            android:background="@color/ai_sidebar_bg"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- 按钮 1：返回（weight=1 顶住 1/3 高度，#1A1A1A 暗灰卡片底） -->
            <LinearLayout
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_skill_sidebar_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_arrow_left"
                    app:tint="@color/ai_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/ai_topbar_back"
                    android:textColor="@color/ai_text_primary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 按钮 2：API 设置（weight=1 顶住中间 1/3 高度，#1A1A1A 暗灰卡片底） -->
            <LinearLayout
                android:id="@+id/btnSettings"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_skill_sidebar_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_key"
                    app:tint="@color/ai_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/skill_sidebar_api"
                    android:textColor="@color/ai_text_primary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 按钮 3：关于（weight=1 顶住底部 1/3 高度，#1A1A1A 暗灰卡片底） -->
            <LinearLayout
                android:id="@+id/btnAbout"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_skill_sidebar_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_info"
                    app:tint="@color/ai_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/skill_sidebar_about"
                    android:textColor="@color/ai_text_primary"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ============ 右侧主区：上下 1:1 分割 ============ -->
        <LinearLayout
            android:id="@+id/rightArea"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/sidebar"
            app:layout_constraintTop_toTopOf="parent">

            <!-- 上半：输入区（EditText + 底部 模型按钮 + 运行按钮） -->
            <LinearLayout
                android:id="@+id/inputSection"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!--
                    EditText：textMultiLine + scrollbars + verticalScroll
                    - 不套外层 ScrollView，否则 EditText 内部滚动与外层滚动冲突
                    - maxLines=999 让 EditText 撑高到 weight=1 给出的可用空间
                    - 不加 background，去掉外框，与下方输出区 TextView 视觉一致
                    - padding 与 outputSection（20/16）保持一致
                -->
                <EditText
                    android:id="@+id/etInput"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:gravity="top|start"
                    android:hint="@string/skill_run_input_hint_default"
                    android:imeOptions="actionSend"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="999"
                    android:paddingStart="20dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="8dp"
                    android:scrollbarStyle="outsideInset"
                    android:scrollbars="vertical"
                    android:textColor="@color/ai_text_primary"
                    android:textColorHint="@color/ai_text_tertiary"
                    android:textSize="15sp"
                    android:verticalScrollbarPosition="defaultPosition"
                    tools:ignore="Autofill,LabelFor" />

                <!-- 底部行：flex Space + 模型选择（wrap_content，靠右灰底） + 运行按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="8dp">

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/btnModel"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_skill_model_btn"
                        android:clickable="true"
                        android:drawableEnd="@drawable/ic_chevron_down"
                        android:drawablePadding="4dp"
                        android:ellipsize="end"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:maxLines="1"
                        android:maxWidth="160dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp"
                        android:textColor="@color/ai_text_primary"
                        android:textSize="13sp"
                        tools:text="默认" />

                    <FrameLayout
                        android:id="@+id/btnRun"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_send_btn"
                        android:clickable="true"
                        android:contentDescription="@string/skill_run_action"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivRunIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_send"
                            app:tint="@color/ai_send_icon" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 中间分割线 -->
            <View
                android:id="@+id/vDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ai_sidebar_divider" />

            <!-- 下半：输出区（ScrollView + TextView） -->
            <ScrollView
                android:id="@+id/outputSection"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp"
                android:scrollbarDefaultDelayBeforeFade="100"
                android:scrollbarFadeDuration="200"
                android:scrollbarSize="4dp"
                android:scrollbarStyle="outsideInset"
                android:scrollbarThumbVertical="@drawable/scrollbar_thumb_ai">

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/ai_text_primary"
                    android:textIsSelectable="true"
                    android:textSize="15sp"
                    tools:text="这里会显示 AI 的回答…" />
            </ScrollView>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ============ 右侧抽屉：模型选择（与 AskAiActivity 同款，ModelDrawerBinder 绑定） ============ -->
    <LinearLayout
        android:id="@+id/drawerModels"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/ai_sidebar_bg"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical">

        <!-- 抽屉顶部：标题 + 关闭 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/ai_model_select_title"
                android:textColor="@color/ai_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCloseDrawer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/ai_model_select_close"
                android:textColor="@color/ai_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@color/ai_sidebar_divider" />

        <!-- 模型列表 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ListView
                android:id="@+id/lvModelsInDrawer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:divider="@null"
                android:listSelector="?attr/selectableItemBackground"
                android:overScrollMode="ifContentScrolls"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:scrollbars="none"
                tools:listitem="@layout/item_model_drawer" />

            <TextView
                android:id="@+id/tvDrawerEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="24dp"
                android:text="@string/ai_model_select_empty"
                android:textColor="@color/ai_text_secondary"
                android:textSize="13sp"
                android:visibility="gone" />
        </FrameLayout>

        <!-- 抽屉底部：API 设置入口（与 AskAiActivity 同款） -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@color/ai_sidebar_divider" />

        <LinearLayout
            android:id="@+id/settingsRow"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_key"
                app:tint="@color/ai_text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/ai_settings_entry"
                android:textColor="@color/ai_text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
