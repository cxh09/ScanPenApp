<?xml version="1.0" encoding="utf-8"?>
<!--
    歌单详情页（占位壳）：
    - 顶栏 32dp：左返回 + 中间歌单名
    - 主体居中显示「歌单详情暂未对接 / 正在播日推」+ 「播日推」按钮
    - 真实接入 [/playlist/detail] 后把歌曲列表放进来
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:orientation="vertical">

    <!-- 顶栏 32dp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageView
            android:id="@+id/btnPlaylistDetailBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_topbar_btn"
            android:clickable="true"
            android:contentDescription="@string/ai_settings_back"
            android:focusable="true"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/text_primary" />

        <TextView
            android:id="@+id/tvPlaylistDetailName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/music_playlist_detail_title"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_strong" />

    <!-- 主体：占位文案 + 按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/music_playlist_detail_placeholder"
            android:textColor="@color/text_tertiary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnPlaylistDetailPlayDaily"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_topbar_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="120dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/music_playlist_detail_play_daily"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
