<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_chat_bg"
    android:orientation="vertical">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="12dp"
            android:text="@string/ai_settings_back"
            android:textColor="@color/ai_input_focus_border"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/about_title"
            android:textColor="@color/ai_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="48dp"
            android:layout_height="match_parent" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ai_sidebar_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="8dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <!-- 设备 -->
            <TextView
                style="@style/AboutSectionHeader"
                android:text="@string/about_section_device" />

            <include
                android:id="@+id/rowManufacturer"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowBrand"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowModel"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowProduct"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowDevice"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowHardware"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowBoard"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowAbis"
                layout="@layout/item_about_row" />

            <!-- 系统 -->
            <TextView
                style="@style/AboutSectionHeader"
                android:text="@string/about_section_system" />

            <include
                android:id="@+id/rowAndroidVersion"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowSdkInt"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowCodename"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowIncremental"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowBuildId"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowFingerprint"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowLocale"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowTimezone"
                layout="@layout/item_about_row" />

            <!-- 内存与存储 -->
            <TextView
                style="@style/AboutSectionHeader"
                android:text="@string/about_section_memory" />

            <include
                android:id="@+id/rowTotalMem"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowAvailMem"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowLowMem"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowTotalStorage"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowAvailStorage"
                layout="@layout/item_about_row" />

            <!-- 屏幕 -->
            <TextView
                style="@style/AboutSectionHeader"
                android:text="@string/about_section_display" />

            <include
                android:id="@+id/rowResolution"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowScreenSize"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowScreenDensity"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowRefreshRate"
                layout="@layout/item_about_row" />

            <!-- 应用 -->
            <TextView
                style="@style/AboutSectionHeader"
                android:text="@string/about_section_app" />

            <include
                android:id="@+id/rowAppVersion"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowVersionCode"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowTargetSdk"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowMinSdk"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowPackage"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowFirstInstall"
                layout="@layout/item_about_row" />

            <include
                android:id="@+id/rowLastUpdate"
                layout="@layout/item_about_row" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
