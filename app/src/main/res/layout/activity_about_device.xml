<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_chat_bg"
    android:orientation="vertical">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_topbar_btn"
            android:clickable="true"
            android:contentDescription="@string/ai_settings_back"
            android:focusable="true"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/ai_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/about_title"
            android:textColor="@color/ai_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="48dp"
            android:layout_height="match_parent" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ai_sidebar_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="12dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <include
                android:id="@+id/rowManufacturer"
                layout="@layout/item_about_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ai_sidebar_divider" />

            <include
                android:id="@+id/rowModel"
                layout="@layout/item_about_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ai_sidebar_divider" />

            <include
                android:id="@+id/rowAndroidVersion"
                layout="@layout/item_about_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ai_sidebar_divider" />

            <include
                android:id="@+id/rowTotalMem"
                layout="@layout/item_about_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ai_sidebar_divider" />

            <include
                android:id="@+id/rowAvailMem"
                layout="@layout/item_about_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ai_sidebar_divider" />

            <include
                android:id="@+id/rowTotalStorage"
                layout="@layout/item_about_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ai_sidebar_divider" />

            <include
                android:id="@+id/rowAvailStorage"
                layout="@layout/item_about_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ai_sidebar_divider" />

            <include
                android:id="@+id/rowResolution"
                layout="@layout/item_about_row" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ai_sidebar_divider" />

            <include
                android:id="@+id/rowAppVersion"
                layout="@layout/item_about_row" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
