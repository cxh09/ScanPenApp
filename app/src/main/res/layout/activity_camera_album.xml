<?xml version="1.0" encoding="utf-8"?>
<!--
    应用内相册（ScanAppCamera）页面（横屏 1:4）：
    - 顶部 48dp 工具栏：「← 返回」+ 标题 + 数量 + 1dp 分隔线
    - 主体：RecyclerView 2 列网格；空态时居中显示「还没有照片」+ 引导文案
    - 深色主题，颜色全部 @color/ai_*，字符串全部 @string/camera_album_*
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_chat_bg"
    android:orientation="vertical">

    <!-- 顶部工具栏：48dp，sidebar 背景 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/ai_sidebar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:contentDescription="@string/ai_fullscreen_back"
            android:focusable="true"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/ai_text_primary" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingStart="8dp"
            android:text="@string/camera_album_title"
            android:textColor="@color/ai_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingEnd="16dp"
            android:textColor="@color/ai_text_tertiary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 工具栏与主体之间的 1dp 分隔线 -->
    <View
        android:id="@+id/toolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ai_sidebar_divider" />

    <!-- 主体：RecyclerView 网格 + 空态容器 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPhotos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="8dp"
            android:scrollbars="none" />

        <LinearLayout
            android:id="@+id/emptyContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/camera_album_empty"
                android:textColor="@color/ai_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmptyHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/camera_album_empty_hint"
                android:textColor="@color/ai_text_tertiary"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
