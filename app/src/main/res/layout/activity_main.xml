<?xml version="1.0" encoding="utf-8"?>
<!--
    主页：单行横向滚动列表（HorizontalScrollView 套 LinearLayout(horizontal)）。
    - 5 个 cell 从左到右排布：问 AI / 微聊 / 设置 / 相机 / 录音机
    - 每个 cell 固定宽度 88dp，超过可视区域的部分由用户左右滑动发现
    - 词典笔屏幕接近 1:4 比例，窄长横屏，单行横滑比 2×3 网格更符合硬件形态
-->
<HorizontalScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:overScrollMode="never"
    android:scrollbars="none"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp">

        <!-- 问 AI -->
        <LinearLayout
            android:id="@+id/btnAskAi"
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_main_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="12dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@string/btn_ask_ai"
                android:src="@drawable/ic_ask_ai" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/btn_ask_ai"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 微聊 -->
        <LinearLayout
            android:id="@+id/btnMicroChat"
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_main_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="12dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@string/btn_micro_chat"
                android:src="@drawable/ic_micro_chat" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/btn_micro_chat"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 设置 -->
        <LinearLayout
            android:id="@+id/btnSettings"
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_main_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="12dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@string/btn_settings"
                android:src="@drawable/ic_settings" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/btn_settings"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 相机 -->
        <LinearLayout
            android:id="@+id/btnCamera"
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_main_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="12dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@string/btn_camera"
                android:src="@drawable/ic_camera" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/btn_camera"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 录音机 -->
        <LinearLayout
            android:id="@+id/btnRecorder"
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_main_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="12dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@string/btn_recorder"
                android:src="@drawable/ic_recorder" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/btn_recorder"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</HorizontalScrollView>
