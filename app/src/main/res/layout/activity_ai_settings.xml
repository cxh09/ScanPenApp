<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_chat_bg"
    android:orientation="vertical">

    <!-- ===== 顶部栏 ===== -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="12dp"
            android:text="@string/ai_settings_back"
            android:textColor="@color/ai_input_focus_border"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/ai_settings_title"
            android:textColor="@color/ai_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:text="@string/ai_settings_save"
            android:textColor="@color/ai_input_focus_border"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnShare"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/ai_settings_share"
            android:textColor="@color/ai_input_focus_border"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnScan"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"
            android:text="@string/ai_settings_scan"
            android:textColor="@color/ai_input_focus_border"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ai_sidebar_divider" />

    <!-- ===== 表单内容 ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="8dp"
            android:paddingEnd="20dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ai_settings_subtitle"
                android:textColor="@color/ai_text_secondary"
                android:textSize="12sp" />

            <!-- API Key -->
            <TextView
                android:id="@+id/tvLabelKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/ai_settings_api_key_hint"
                android:textColor="@color/ai_text_primary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_ai_settings_field"
                android:fontFamily="monospace"
                android:hint="@string/ai_settings_api_key_hint"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp"
                android:textColor="@color/ai_text_primary"
                android:textColorHint="@color/ai_text_tertiary"
                android:textSize="14sp"
                tools:ignore="Autofill,LabelFor" />

            <!-- Base URL -->
            <TextView
                android:id="@+id/tvLabelBase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/ai_settings_base_url_hint"
                android:textColor="@color/ai_text_primary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etBaseUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_ai_settings_field"
                android:fontFamily="monospace"
                android:hint="https://api.openai.com/v1/"
                android:imeOptions="actionNext"
                android:inputType="textUri"
                android:maxLines="1"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp"
                android:textColor="@color/ai_text_primary"
                android:textColorHint="@color/ai_text_tertiary"
                android:textSize="14sp"
                tools:ignore="Autofill,LabelFor" />

            <!-- Base URL 预设 -->
            <LinearLayout
                android:id="@+id/presetRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvPresetLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_settings_preset_title"
                    android:textColor="@color/ai_text_tertiary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btnPresetDeepseek"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_ai_settings_field"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="@string/ai_settings_preset_deepseek"
                    android:textColor="@color/ai_input_focus_border"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnPresetOpencode"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_ai_settings_field"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="@string/ai_settings_preset_opencode"
                    android:textColor="@color/ai_input_focus_border"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnPresetGlm"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_ai_settings_field"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="@string/ai_settings_preset_glm"
                    android:textColor="@color/ai_input_focus_border"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Model -->
            <TextView
                android:id="@+id/tvLabelModel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/ai_settings_model_hint"
                android:textColor="@color/ai_text_primary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_ai_settings_field"
                android:fontFamily="monospace"
                android:hint="gpt-4o-mini"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp"
                android:textColor="@color/ai_text_primary"
                android:textColorHint="@color/ai_text_tertiary"
                android:textSize="14sp"
                tools:ignore="Autofill,LabelFor" />

            <!-- 测试按钮 + 状态 -->
            <LinearLayout
                android:id="@+id/testRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnTest"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="@string/ai_settings_test"
                    android:textColor="@color/ai_input_focus_border"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTestStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/ai_text_secondary"
                    android:textSize="12sp"
                    tools:text="连接成功" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
