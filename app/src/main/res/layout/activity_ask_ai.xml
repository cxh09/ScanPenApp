<?xml version="1.0" encoding="utf-8"?>
<!--
    问 AI 页面：根 = DrawerLayout（仅支持右侧 end 抽屉）。
    - 第一个子（content）：原 ConstraintLayout，整张主界面。
    - 第二个子（drawer）：模型选择抽屉，宽 280dp，从屏幕右侧滑出。
    - 抽屉默认 lockMode=locked，仅 btnModel 可触发打开，避免误滑。
-->
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ============ 主内容 ============ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ai_chat_bg">

        <!-- ============ 左侧侧边栏 ============ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/sidebar"
            android:layout_width="220dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_sidebar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- 新对话按钮 -->
            <LinearLayout
                android:id="@+id/btnNewChat"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_btn_new_chat"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_plus"
                    app:tint="@color/ai_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/ai_new_chat"
                    android:textColor="@color/ai_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:id="@+id/divider"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="12dp"
                android:background="@color/ai_sidebar_divider"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnNewChat" />

            <!-- 历史对话 标题 -->
            <TextView
                android:id="@+id/tvHistoryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:text="@string/ai_history_title"
                android:textColor="@color/ai_text_tertiary"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider" />

            <!-- 历史列表 -->
            <ListView
                android:id="@+id/lvHistory"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="4dp"
                android:clipToPadding="false"
                android:descendantFocusability="blocksDescendants"
                android:divider="@null"
                android:listSelector="?attr/selectableItemBackground"
                android:overScrollMode="always"
                android:paddingBottom="8dp"
                android:scrollbars="none"
                app:layout_constraintBottom_toTopOf="@id/settingsRow"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvHistoryTitle"
                tools:listitem="@layout/item_chat_history" />

            <!-- 设置入口 -->
            <LinearLayout
                android:id="@+id/settingsRow"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_key"
                    app:tint="@color/ai_text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/ai_settings_entry"
                    android:textColor="@color/ai_text_secondary"
                    android:textSize="14sp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 侧边栏与主区之间的细分隔线 -->
        <View
            android:id="@+id/sidebarDivider"
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:background="@color/ai_sidebar_divider"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/sidebar"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ============ 右侧主区 ============ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mainArea"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/sidebarDivider"
            app:layout_constraintTop_toTopOf="parent">

            <!-- 中央内容区：聊天消息 -->
            <ScrollView
                android:id="@+id/svMessages"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:fillViewport="true"
                android:overScrollMode="always"
                android:paddingStart="24dp"
                android:paddingTop="12dp"
                android:paddingEnd="24dp"
                android:paddingBottom="12dp"
                app:layout_constraintBottom_toTopOf="@id/inputBar"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:id="@+id/llMessages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <!-- 底部输入栏：单行 输入框 | 思考 | 模型 | 加号 | 发送 -->
            <LinearLayout
                android:id="@+id/inputBar"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <EditText
                    android:id="@+id/etInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/ai_input_hint"
                    android:imeOptions="actionSend"
                    android:inputType="textCapSentences"
                    android:maxLines="1"
                    android:textColor="@color/ai_text_primary"
                    android:textColorHint="@color/ai_text_tertiary"
                    android:textSize="14sp"
                    tools:ignore="Autofill,LabelFor" />

                <TextView
                    android:id="@+id/btnQuick"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_ai_thinking_toggle"
                    android:clickable="true"
                    android:drawableStart="@drawable/ic_bulb"
                    android:drawablePadding="4dp"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="@string/ai_thinking"
                    android:textColor="@color/ai_text_primary"
                    android:textSize="14sp" />

                <!-- 模型选择按钮（点击打开右抽屉） -->
                <TextView
                    android:id="@+id/btnModel"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_ai_thinking_toggle"
                    android:clickable="true"
                    android:drawableEnd="@drawable/ic_chevron_down"
                    android:drawablePadding="4dp"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:maxLines="1"
                    android:maxWidth="120dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="6dp"
                    android:text="@string/ai_model_select_default"
                    android:textColor="@color/ai_text_primary"
                    android:textSize="13sp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@color/ai_sidebar_divider" />

                <ImageView
                    android:id="@+id/btnAdd"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/ai_quick_action"
                    android:focusable="true"
                    android:padding="8dp"
                    android:src="@drawable/ic_plus"
                    app:tint="@color/ai_text_secondary" />

                <FrameLayout
                    android:id="@+id/btnSend"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="2dp"
                    android:background="@drawable/bg_send_btn"
                    android:clickable="true"
                    android:contentDescription="@string/ai_send_voice"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_send" />
                </FrameLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ============ 右侧抽屉：模型选择 ============ -->
    <LinearLayout
        android:id="@+id/drawerModels"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/ai_sidebar_bg"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical">

        <!-- 抽屉顶部：标题 + 关闭 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/ai_model_select_title"
                android:textColor="@color/ai_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCloseDrawer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/ai_model_select_close"
                android:textColor="@color/ai_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@color/ai_sidebar_divider" />

        <!-- 模型列表 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ListView
                android:id="@+id/lvModelsInDrawer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:divider="@null"
                android:listSelector="?attr/selectableItemBackground"
                android:overScrollMode="ifContentScrolls"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:scrollbars="none"
                tools:listitem="@layout/item_model_drawer" />

            <TextView
                android:id="@+id/tvDrawerEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="24dp"
                android:text="@string/ai_model_select_empty"
                android:textColor="@color/ai_text_secondary"
                android:textSize="13sp"
                android:visibility="gone" />
        </FrameLayout>

        <!-- 底部跳转到 AI 服务 -->
        <LinearLayout
            android:id="@+id/btnGotoSettings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_key"
                app:tint="@color/ai_text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/ai_model_select_goto_settings"
                android:textColor="@color/ai_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
