<?xml version="1.0" encoding="utf-8"?>
<!--
    录音机页面：根 = LinearLayout(horizontal)
    - 左侧 220dp 侧栏：顶部「＋新录音」按钮 + 分隔线 + 录音列表 RecyclerView + 空态
    - 右侧主区：FrameLayout 叠加 recordPanel（默认 visible）/ playPanel（默认 gone）
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:orientation="horizontal">

    <!-- ============ 左侧 220dp 侧栏 ============ -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:background="@color/recorder_sidebar_bg"
        android:orientation="vertical">

        <!--
            顶部工具栏：左 40×40 灰底返回按钮 + 占满剩余空间的「＋新录音」灰底按钮。
            仿问 AI 页面 toolbarLayout 的 40×40 灰底样式（bg_topbar_btn：level-1 → 按下 level-2）。
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- 返回（仿问 AI 顶部按钮） -->
            <ImageView
                android:id="@+id/btnRecorderBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_topbar_btn"
                android:clickable="true"
                android:contentDescription="@string/recorder_back"
                android:focusable="true"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_arrow_left"
                app:tint="@color/recorder_text_primary" />

            <!-- ＋新录音：占满剩余宽度 -->
            <LinearLayout
                android:id="@+id/btnNewRecording"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_topbar_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:id="@+id/ivNew"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_plus"
                    app:tint="@color/recorder_text_primary" />

                <TextView
                    android:id="@+id/tvNewLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/recorder_new"
                    android:textColor="@color/recorder_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@color/recorder_sidebar_divider" />

        <!-- 列表区：RecyclerView + 空态 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecordings"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="vertical"
                tools:listitem="@layout/item_recording" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="@string/recorder_empty"
                android:textColor="@color/recorder_text_tertiary"
                android:textSize="13sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- ============ 右侧主区 ============ -->
    <LinearLayout
        android:id="@+id/mainArea"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/bg_base"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- ============ 录制态（默认 visible） ============ -->
            <LinearLayout
                android:id="@+id/recordPanel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <Chronometer
                    android:id="@+id/chronometer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:textColor="@color/text_primary"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRecordHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:text="@string/recorder_idle"
                    android:textColor="@color/text_tertiary"
                    android:textSize="14sp" />

                <FrameLayout
                    android:id="@+id/btnRecord"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_record_btn_idle"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvRecordBtnLabel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="●"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvRecordStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:text=""
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvMicNeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:text="@string/recorder_mic_need"
                    android:textColor="@color/state_error"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btnMicGoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_ai_settings_field"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="20dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="10dp"
                    android:text="@string/recorder_mic_goto"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ============ 播放态（默认 gone） ============ -->
            <LinearLayout
                android:id="@+id/playPanel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingTop="16dp"
                android:paddingEnd="32dp"
                android:paddingBottom="16dp"
                android:visibility="gone">

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvPlayName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPlayTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"
                    android:text="0:00 / 0:00"
                    android:textColor="@color/text_tertiary"
                    android:textSize="13sp" />

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="1000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- 暂停 / 继续（toggle 按钮：图标在 pause ⇄ play 之间切换） -->
                    <ImageView
                        android:id="@+id/btnPlayPause"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_play_btn"
                        android:clickable="true"
                        android:contentDescription="@string/recorder_pause"
                        android:focusable="true"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_pause"
                        app:tint="@color/text_primary" />

                    <!-- 删除 -->
                    <ImageView
                        android:id="@+id/btnDelete"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_play_btn"
                        android:clickable="true"
                        android:contentDescription="@string/recorder_delete"
                        android:focusable="true"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_trash"
                        app:tint="@color/state_error" />
                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
