<?xml version="1.0" encoding="utf-8"?>
<!--
  笔记编辑器背景：圆角 12dp，note_editor_bg（与列表项同款中性灰，比纯黑略亮）。
  - 标题 EditText / 正文 EditText / 工具栏共用，让右侧视觉连贯。
  - 单层 shape，无 inset（标题与正文外层已有 margin 8dp 留白）。
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/note_editor_bg" />
    <corners android:radius="12dp" />
</shape>
