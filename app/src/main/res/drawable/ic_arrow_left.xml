<?xml version="1.0" encoding="utf-8"?>
<!--
  返回图标（lucide `arrow-left` 风格的忠实转换）。
  - 24dp viewport；圆角线端（strokeLineCap=round, strokeLineJoin=round）
  - fill=transparent（对应 SVG 的 fill="none"），仅描边渲染
  - 颜色由 ImageView 侧的 `app:tint="@color/*"` 决定；本文件 strokeColor 仅作占位
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M19,12 L5,12"
        android:strokeColor="@color/text_primary"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="2" />
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M12,19 L5,12 L12,5"
        android:strokeColor="@color/text_primary"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="2" />
</vector>
