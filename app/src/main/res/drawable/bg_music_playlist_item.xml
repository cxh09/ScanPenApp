<?xml version="1.0" encoding="utf-8"?>
<!--
    歌单 item 背景：复用录音机的三段式 StateListDrawable
    - 激活 / 按下：surface_level_1
    - 默认：bg_elevated_1（与录音项一致）
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_level_1" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_level_1" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_elevated_1" />
        </shape>
    </item>
</selector>
